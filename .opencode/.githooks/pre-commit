#!/bin/bash
echo "=== Pre-commit checks ==="
cd "$(git rev-parse --show-toplevel)/.opencode" || exit 1

FILES=("bot/core.py" "bot/features.py" "bot/config.py" "bot/security.py" "bot/images.py" "gaming_news_bot.py")
for f in "${FILES[@]}"; do
    python -c "import py_compile; py_compile.compile('$f', doraise=True)" 2>&1 || {
        echo "FAIL: $f"
        exit 1
    }
    echo "OK: $f"
done

python -m pytest tests/ -q 2>&1 || {
    echo "FAIL: tests"
    exit 1
}

echo "=== All checks passed ==="
